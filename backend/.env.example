# Configuração do banco de dados PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
DATABASE_URL="postgresql://postgres:senha@localhost:5432/app_scholar"

# Chave secreta para assinar os tokens JWT
# Em produção, use uma string longa e aleatória
JWT_SECRET="sua_chave_secreta_aqui_troque_em_producao"

# Tempo de expiração do token JWT (1d = 1 dia, 7d = 7 dias)
JWT_EXPIRES_IN="7d"

# Porta do servidor backend
PORT=3001

# Ambiente de execução
NODE_ENV="development"
