// Configuração do banco de dados e gerador do Prisma Client
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum que define os perfis de acesso do sistema
// ADMIN: acesso total ao sistema
// PROFESSOR: acesso às disciplinas e notas de seus alunos
// ALUNO: acesso somente leitura ao próprio boletim
enum Perfil {
  ADMIN
  PROFESSOR
  ALUNO
}

// Tabela de usuários: responsável pela autenticação e perfil de acesso
// Cada usuário tem exatamente um perfil relacionado (Aluno ou Professor)
model Usuario {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  senha          String // Hash bcrypt da senha
  perfil         Perfil
  primeiroAcesso Boolean  @default(true) // Força troca de senha no primeiro login
  ativo          Boolean  @default(true) // Permite desativar usuários sem excluir
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  // Relacionamentos opcionais — apenas um dos dois existirá para cada usuário
  aluno     Aluno?
  professor Professor?

  @@map("usuarios") // Nome real da tabela no banco
}

// Tabela de alunos com dados pessoais e acadêmicos
model Aluno {
  id           Int      @id @default(autoincrement())
  usuarioId    Int      @unique
  nome         String
  matricula    String   @unique // Matrícula acadêmica única
  curso        String
  telefone     String?
  cep          String?
  endereco     String? // Preenchido automaticamente via ViaCEP
  cidade       String?
  estado       String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // Relacionamento com o usuário de autenticação
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  // Um aluno pode ter muitas notas (uma por disciplina)
  notas Nota[]

  @@map("alunos")
}

// Tabela de professores com dados profissionais
model Professor {
  id            Int      @id @default(autoincrement())
  usuarioId     Int      @unique
  nome          String
  titulacao     String? // Ex: Mestre, Doutor, Especialista
  area          String? // Área de atuação
  tempoDocencia Int? // Tempo de docência em anos
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  // Relacionamento com o usuário de autenticação
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  // Um professor pode lecionar várias disciplinas
  disciplinas Disciplina[]

  @@map("professores")
}

// Tabela de disciplinas — cada disciplina pertence a um professor
model Disciplina {
  id           Int       @id @default(autoincrement())
  nome         String
  cargaHoraria Int
  professorId  Int
  curso        String
  semestre     Int
  descricao    String?
  ativo        Boolean   @default(true) // true = semestre atual | false = semestre encerrado (notas bloqueadas)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
  professor    Professor @relation(fields: [professorId], references: [id])
  notas        Nota[]

  @@map("disciplinas")
}

// Tabela de notas — intersecção entre Aluno e Disciplina
model Nota {
  id           Int      @id @default(autoincrement())
  alunoId      Int
  disciplinaId Int
  nota1        Float? // Primeira avaliação (0 a 10)
  nota2        Float? // Segunda avaliação (0 a 10)
  media        Float? // Calculada automaticamente: (nota1 + nota2) / 2
  situacao     String? // "Aprovado", "Recuperação" ou "Reprovado"
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // Relacionamentos com aluno e disciplina
  aluno      Aluno      @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  disciplina Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)

  // Um aluno só pode ter uma nota por disciplina
  @@unique([alunoId, disciplinaId])
  @@map("notas")
}
