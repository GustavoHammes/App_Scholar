// Configuração do banco de dados e gerador do Prisma Client
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum que define os perfis de acesso do sistema
// ADMIN: acesso total ao sistema
// PROFESSOR: acesso às disciplinas e notas de seus alunos
// ALUNO: acesso somente leitura ao próprio boletim
enum Perfil {
  ADMIN
  PROFESSOR
  ALUNO
}

// Tabela de usuários: responsável pela autenticação e perfil de acesso
// Cada usuário tem exatamente um perfil relacionado: Aluno ou Professor.
// O usuário ADMIN não possui vínculo obrigatório com Aluno ou Professor.
model Usuario {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  senha          String // Hash bcrypt da senha
  perfil         Perfil
  primeiroAcesso Boolean  @default(true) // Força troca de senha no primeiro login
  ativo          Boolean  @default(true) // Permite desativar usuários sem excluir
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  // Relacionamentos opcionais — apenas um dos dois existirá para professor/aluno
  aluno     Aluno?
  professor Professor?

  @@map("usuarios")
}

// Tabela de cursos da instituição
// Usada para cadastro, gerenciamento e vínculo com alunos e disciplinas
model Curso {
  id Int @id @default(autoincrement())

  nome             String  @unique
  area             String
  duracaoSemestres Int
  descricao        String?
  ativo            Boolean @default(true)

  // Professor responsável pela coordenação do curso
  coordenadorId Int?
  coordenador   Professor? @relation("CoordenadorCurso", fields: [coordenadorId], references: [id], onDelete: SetNull)

  // Relacionamentos
  alunos      Aluno[]
  disciplinas Disciplina[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([coordenadorId])
  @@map("cursos")
}

// Tabela de alunos com dados pessoais e acadêmicos
model Aluno {
  id        Int @id @default(autoincrement())
  usuarioId Int @unique

  nome      String
  matricula String @unique

  // Vínculo real com a tabela de cursos
  cursoId Int
  curso   Curso @relation(fields: [cursoId], references: [id])

  telefone String?
  cep      String?
  endereco String?
  cidade   String?
  estado   String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  notas   Nota[]

  @@index([cursoId])
  @@map("alunos")
}

// Tabela de professores
model Professor {
  id        Int @id @default(autoincrement())
  usuarioId Int @unique

  nome          String
  titulacao     String?
  area          String?
  tempoDocencia Int?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  // Disciplinas ministradas pelo professor
  disciplinas Disciplina[]

  // Cursos coordenados pelo professor
  cursosCoordenados Curso[] @relation("CoordenadorCurso")

  @@map("professores")
}

// Tabela de disciplinas
model Disciplina {
  id Int @id @default(autoincrement())

  nome         String
  cargaHoraria Int
  professorId  Int

  // Vínculo real com a tabela de cursos
  cursoId Int
  curso   Curso @relation(fields: [cursoId], references: [id])

  semestre  Int
  descricao String?
  ativo     Boolean @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  professor Professor @relation(fields: [professorId], references: [id])
  notas     Nota[]

  @@index([professorId])
  @@index([cursoId])
  @@map("disciplinas")
}

// Tabela de notas dos alunos por disciplina
model Nota {
  id Int @id @default(autoincrement())

  alunoId      Int
  disciplinaId Int

  nota1    Float
  nota2    Float
  media    Float
  situacao String

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  aluno      Aluno      @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  disciplina Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)

  // Evita lançar duas notas para o mesmo aluno na mesma disciplina
  @@unique([alunoId, disciplinaId])
  @@index([disciplinaId])
  @@map("notas")
}
